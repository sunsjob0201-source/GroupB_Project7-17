<%@ page pageEncoding="UTF-8" contentType="text/html; charset=UTF-8" %>
<%@ include file="common/header.jspf" %><div class="title-row"><h1>商品管理</h1><a class="button" href="${pageContext.request.contextPath}/admin/products/new">商品を追加</a></div><div class="table-wrap"><table><thead><tr><th>ID</th><th>商品名</th><th>単価</th><th>在庫</th><th>操作</th></tr></thead><tbody><c:forEach items="${products}" var="p"><tr><td>${p.id}</td><td>${p.name}</td><td>¥${p.price}</td><td>${p.stock}</td><td class="row"><a class="small" href="${pageContext.request.contextPath}/admin/products/${p.id}/edit">変更</a><form method="post" action="${pageContext.request.contextPath}/admin/products/${p.id}/delete" onsubmit="return confirm('削除しますか？')"><input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}"><button class="danger">削除</button></form></td></tr></c:forEach></tbody></table></div><%@ include file="common/footer.jspf" %>

