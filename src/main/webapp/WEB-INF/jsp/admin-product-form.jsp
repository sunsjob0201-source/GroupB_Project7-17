<%@ page pageEncoding="UTF-8" contentType="text/html; charset=UTF-8" %>
<%@ include file="common/header.jspf" %><%@ taglib prefix="form" uri="http://www.springframework.org/tags/form" %><section class="panel"><h1>${empty productId ? '商品を追加' : '商品を変更'}</h1><form:form modelAttribute="productForm" method="post" action="${pageContext.request.contextPath}/admin/products/save" class="form-grid"><c:if test="${not empty productId}"><input type="hidden" name="productId" value="${productId}"></c:if><label>商品名称<form:input path="name"/><form:errors path="name" cssClass="field-error"/></label><label>単価<form:input type="number" path="price" min="0"/><form:errors path="price" cssClass="field-error"/></label><label class="wide">商品説明<form:textarea path="description" rows="5"/><form:errors path="description" cssClass="field-error"/></label><label>在庫数量<form:input type="number" path="stock" min="0"/></label><label>商品画像URL<form:input path="imageUrl"/></label><div class="wide actions"><button class="button">保存</button><a class="button secondary" href="${pageContext.request.contextPath}/admin/products">戻る</a></div></form:form></section><%@ include file="common/footer.jspf" %>

