<%@ page pageEncoding="UTF-8" contentType="text/html; charset=UTF-8" %>
<%@ include file="common/header.jspf" %><h1>ショッピングカート</h1><c:choose><c:when test="${empty items}"><div class="empty"><p>カートに商品はありません。</p><a class="button" href="${pageContext.request.contextPath}/products">商品を選ぶ</a></div></c:when><c:otherwise><div class="table-wrap"><table><thead><tr><th>商品</th><th>価格</th><th>数量</th><th>小計</th><th></th></tr></thead><tbody><c:forEach items="${items}" var="i"><tr><td><c:out value="${i.product.name}"/></td><td>¥${i.product.price}</td><td><form class="row" action="${pageContext.request.contextPath}/cart/update" method="post"><input type="hidden" name="itemId" value="${i.id}"><input type="number" name="quantity" value="${i.quantity}" min="1" max="${i.product.stock}"><input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}"><button class="small">変更</button></form></td><td>¥${i.product.price * i.quantity}</td><td><form action="${pageContext.request.contextPath}/cart/remove" method="post"><input type="hidden" name="itemId" value="${i.id}"><input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}"><button class="danger">取消</button></form></td></tr></c:forEach></tbody></table></div><p class="total">合計 ¥${total}</p><div class="actions"><a class="button" href="${pageContext.request.contextPath}/checkout">購入する</a><a class="button secondary" href="${pageContext.request.contextPath}/products">商品選択へ戻る</a><a class="button secondary" href="${pageContext.request.contextPath}/menu">メニューへ戻る</a></div></c:otherwise></c:choose><%@ include file="common/footer.jspf" %>

