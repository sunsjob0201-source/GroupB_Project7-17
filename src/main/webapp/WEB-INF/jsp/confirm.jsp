<%@ page pageEncoding="UTF-8" contentType="text/html; charset=UTF-8" %>
<%@ include file="common/header.jspf" %><%@ taglib prefix="form" uri="http://www.springframework.org/tags/form" %><h1>購入内容の確認</h1><div class="summary"><h2>注文者情報</h2><p>${checkoutForm.customerName}<br>${checkoutForm.postalCode} ${checkoutForm.address}<br>${checkoutForm.phone}<br>${checkoutForm.email}<br>${checkoutForm.paymentMethod.label}</p></div><div class="table-wrap"><table><thead><tr><th>商品名</th><th>価格</th><th>数量</th><th>小計</th></tr></thead><tbody><c:forEach items="${items}" var="i"><tr><td>${i.product.name}</td><td>¥${i.product.price}</td><td>${i.quantity}</td><td>¥${i.product.price * i.quantity}</td></tr></c:forEach></tbody></table></div><p class="total">合計 ¥${total}</p><form:form modelAttribute="checkoutForm" method="post" action="${pageContext.request.contextPath}/checkout/complete"><form:hidden path="customerName"/><form:hidden path="postalCode"/><form:hidden path="address"/><form:hidden path="phone"/><form:hidden path="email"/><form:hidden path="paymentMethod"/><button class="button">確定</button><button type="button" class="button secondary" onclick="history.back()">注文者情報へ戻る</button><a class="button secondary" href="${pageContext.request.contextPath}/cart">カートへ戻る</a></form:form><%@ include file="common/footer.jspf" %>

