<%@ page pageEncoding="UTF-8" contentType="text/html; charset=UTF-8" %>
<%@ include file="common/header.jspf" %><h1>商品を選択する</h1><div class="product-grid"><c:forEach items="${products}" var="p"><article class="product-card"><c:choose><c:when test="${not empty p.imageUrl}"><img src="${p.imageUrl}" alt=""></c:when><c:otherwise><div class="placeholder">No image</div></c:otherwise></c:choose><div class="card-body"><h2><c:out value="${p.name}"/></h2><p><c:out value="${p.description}"/></p><p class="price">¥<c:out value="${p.price}"/></p><c:choose><c:when test="${p.stock > 0}"><form action="${pageContext.request.contextPath}/cart/add" method="post" class="row"><input type="hidden" name="productId" value="${p.id}"><input type="number" name="quantity" value="1" min="1" max="${p.stock}" aria-label="数量"><input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}"><button class="button">カートへ</button></form><small>在庫 ${p.stock}点</small></c:when><c:otherwise><button disabled>在庫切れ</button></c:otherwise></c:choose></div></article></c:forEach></div><%@ include file="common/footer.jspf" %>

