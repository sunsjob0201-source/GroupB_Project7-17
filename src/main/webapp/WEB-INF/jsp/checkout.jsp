<%@ page pageEncoding="UTF-8" contentType="text/html; charset=UTF-8" %>
<%@ include file="common/header.jspf" %><%@ taglib prefix="form" uri="http://www.springframework.org/tags/form" %><section class="panel"><h1>注文者情報の入力</h1><p>会員情報を初期表示しています。ここでの変更は会員情報には反映されません。</p><form:form modelAttribute="checkoutForm" method="post" action="${pageContext.request.contextPath}/checkout/confirm" class="form-grid"><label>氏名<form:input path="customerName"/><form:errors path="customerName" cssClass="field-error"/></label><label>郵便番号<div class="row"><form:input path="postalCode" id="postalCode"/><button type="button" class="small" onclick="searchAddress()">住所検索</button></div><form:errors path="postalCode" cssClass="field-error"/></label><label class="wide">住所<form:input path="address" id="address"/><form:errors path="address" cssClass="field-error"/></label><label>電話番号<form:input path="phone"/><form:errors path="phone" cssClass="field-error"/></label><label>メールアドレス<form:input path="email"/><form:errors path="email" cssClass="field-error"/></label><label>支払方法<form:select path="paymentMethod"><form:options items="${paymentMethods}" itemLabel="label"/></form:select></label><div class="wide actions"><button class="button">次へ</button><a class="button secondary" href="${pageContext.request.contextPath}/cart">カートへ戻る</a><a class="button secondary" href="${pageContext.request.contextPath}/menu">メニューへ戻る</a></div></form:form></section><%@ include file="common/footer.jspf" %>

